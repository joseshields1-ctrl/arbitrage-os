PORT=3000
# Comma-separated list of allowed frontend origins in production.
# Example: https://specialty-sniper.vercel.app
CORS_ALLOWED_ORIGINS=

# SQLite DB path. In production on Render with a disk mounted at /var/data:
# SQLITE_DB_PATH=/var/data/arbitrage-os.db
SQLITE_DB_PATH=./data/arbitrage-os.db

# Optional assistant key. If empty, assistant returns safe mock/dev response.
OPENAI_API_KEY=
